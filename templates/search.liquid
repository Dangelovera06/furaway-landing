<section class="wrap" style="padding:60px 24px">
  <h1>Search</h1>
  <form action="{{ routes.search_url }}" method="get" role="search">
    <input type="search" name="q" value="{{ search.terms | escape }}" placeholder="Search the shop" style="padding:12px 16px;width:100%;max-width:480px;border:1px solid #ddd;border-radius:8px" />
    <button type="submit" class="btn btn--primary">Search</button>
  </form>
  {% if search.performed %}
    <p style="margin-top:16px">{{ search.results_count }} results for "{{ search.terms }}"</p>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:24px;margin-top:24px">
      {% for item in search.results %}
        <a href="{{ item.url }}" style="text-decoration:none;color:inherit">
          {% if item.featured_image %}<img src="{{ item.featured_image | image_url: width: 400 }}" alt="" style="width:100%;border-radius:12px" />{% endif %}
          <h3>{{ item.title }}</h3>
        </a>
      {% endfor %}
    </div>
  {% endif %}
</section>
