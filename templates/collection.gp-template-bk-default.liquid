<section class="wrap" style="padding:60px 24px">
  <span class="eyebrow">Shop</span>
  <h1>{{ collection.title }}</h1>
  {% if collection.description != blank %}<p class="lede">{{ collection.description }}</p>{% endif %}

  <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:24px;margin-top:32px">
    {% for product in collection.products %}
      <a href="{{ product.url }}" style="text-decoration:none;color:inherit">
        <div style="aspect-ratio:1;background:#f3ede2;border-radius:16px;overflow:hidden">
          <img src="{{ product.featured_image | image_url: width: 600 }}" alt="{{ product.title }}" style="width:100%;height:100%;object-fit:cover" />
        </div>
        <h3 style="margin:12px 0 4px">{{ product.title }}</h3>
        <div>{{ product.price | money_without_trailing_zeros }}</div>
      </a>
    {% else %}
      <p>No products yet.</p>
    {% endfor %}
  </div>
</section>
