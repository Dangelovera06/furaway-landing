{%- assign current_variant = product.selected_or_first_available_variant -%}
{%- assign unit_price = current_variant.price | money_without_trailing_zeros -%}

<main class="pdp">

  <nav class="crumb wrap" aria-label="Breadcrumb">
    <a href="{{ routes.root_url }}">Home</a> <span>/</span>
    <a href="{{ routes.all_products_collection_url }}">Shop</a> <span>/</span>
    <em>{{ section.settings.sku_label }} {{ product.title }}</em>
  </nav>

  <section class="pdp__top">
    <div class="wrap pdp__grid">

      <div class="gallery">
        <div class="gallery__main">
          <img id="mainImg" src="{{ 'hero.png' | asset_url }}" alt="{{ product.title }}" />
        </div>
        <div class="gallery__thumbs" role="tablist">
          <button class="thumb is-active" data-src="{{ 'hero.png' | asset_url }}" aria-label="Studio shot on folded fabric"><img src="{{ 'hero.png' | asset_url }}" alt="" /></button>
          <button class="thumb" data-src="{{ 'colors.png' | asset_url }}" aria-label="All four colors"><img src="{{ 'colors.png' | asset_url }}" alt="" /></button>
          <button class="thumb" data-src="{{ 'bed.png' | asset_url }}" aria-label="Three rollers on a bed"><img src="{{ 'bed.png' | asset_url }}" alt="" /></button>
        </div>
      </div>

      <aside class="buybox">
        <span class="buybox__eyebrow">{{ section.settings.sku_label }} · {{ section.settings.eyebrow }}</span>
        <h1 class="buybox__title">{{ product.title | default: 'The Pet Hair Remover' }}</h1>

        <div class="rating">
          <span class="rating__stars" aria-hidden="true">★★★★★</span>
          <span class="rating__num">{{ section.settings.rating }}</span>
          <a href="#reviews" class="rating__link">{{ section.settings.review_count }} reviews</a>
        </div>

        <p class="buybox__lede">{{ section.settings.lede }}</p>

        <form method="post" action="{{ routes.cart_add_url }}" id="productForm" enctype="multipart/form-data" accept-charset="UTF-8">
          <input type="hidden" name="form_type" value="product" />
          <input type="hidden" name="utf8" value="✓" />
          <input type="hidden" name="id" id="variantId" value="{{ current_variant.id }}" />

          <div class="price-row">
            <span class="price-row__amount" id="priceAmount">{{ unit_price }}</span>
            {%- if current_variant.compare_at_price > current_variant.price -%}
              <span class="price-row__strike">{{ current_variant.compare_at_price | money_without_trailing_zeros }}</span>
              {%- assign discount = current_variant.compare_at_price | minus: current_variant.price | times: 100.0 | divided_by: current_variant.compare_at_price | round -%}
              <span class="price-row__pill">Save {{ discount }}%</span>
            {%- else -%}
              <span class="price-row__strike">{{ section.settings.compare_at_price }}</span>
              <span class="price-row__pill">Save 25%</span>
            {%- endif -%}
          </div>
          <p class="price-row__sub">or 4 interest-free payments of {{ current_variant.price | divided_by: 4 | money_without_trailing_zeros }} with Shop Pay</p>

          <div class="opt">
            <div class="opt__label"><span>Color</span><span id="colorPick">Sage</span></div>
            <div class="opt__row" id="colorRow">
              <button type="button" class="chip is-active" data-name="Sage"><span class="chip__sw" style="background:#bfd0b3"></span><span class="chip__lbl">Sage</span></button>
              <button type="button" class="chip" data-name="Blush"><span class="chip__sw" style="background:#e9bdb6"></span><span class="chip__lbl">Blush</span></button>
              <button type="button" class="chip" data-name="Sky"><span class="chip__sw" style="background:#b9d3df"></span><span class="chip__lbl">Sky</span></button>
              <button type="button" class="chip" data-name="Cloud"><span class="chip__sw" style="background:#efeae0"></span><span class="chip__lbl">Cloud</span></button>
            </div>
          </div>
          <input type="hidden" name="properties[Color]" id="colorInput" value="Sage" />

          <div class="opt">
            <div class="opt__label"><span>Bundle</span><span id="bundlePick">Single · {{ unit_price }}</span></div>
            <div class="bundles" id="bundleRow">
              <label class="bundle is-active" data-qty="1" data-price="{{ current_variant.price }}" data-label="Single · {{ unit_price }}">
                <input type="radio" name="bundle" checked />
                <div class="bundle__top">
                  <span class="bundle__name">Single</span>
                  <span class="bundle__price">{{ unit_price }}</span>
                </div>
                <span class="bundle__sub">1 × {{ section.settings.sku_label }}</span>
              </label>
              <label class="bundle" data-qty="2" data-price="{{ current_variant.price | times: 2 | minus: 600 }}" data-label="Duo">
                <input type="radio" name="bundle" />
                <span class="bundle__flag">Most popular</span>
                <div class="bundle__top">
                  <span class="bundle__name">Duo</span>
                  <span class="bundle__price">{{ current_variant.price | times: 2 | minus: 600 | money_without_trailing_zeros }} <s>{{ current_variant.price | times: 2 | money_without_trailing_zeros }}</s></span>
                </div>
                <span class="bundle__sub">2 × {{ section.settings.sku_label }} · Save $6</span>
              </label>
              <label class="bundle" data-qty="3" data-price="{{ current_variant.price | times: 3 | minus: 1500 }}" data-label="Family">
                <input type="radio" name="bundle" />
                <span class="bundle__flag bundle__flag--alt">Best value</span>
                <div class="bundle__top">
                  <span class="bundle__name">Family</span>
                  <span class="bundle__price">{{ current_variant.price | times: 3 | minus: 1500 | money_without_trailing_zeros }} <s>{{ current_variant.price | times: 3 | money_without_trailing_zeros }}</s></span>
                </div>
                <span class="bundle__sub">3 × {{ section.settings.sku_label }} · Save $15</span>
              </label>
            </div>
          </div>

          <div class="qty-row">
            <div class="qty" role="group" aria-label="Quantity">
              <button type="button" id="qMinus" aria-label="Decrease">−</button>
              <input type="number" name="quantity" id="qVal" value="1" min="1" readonly />
              <button type="button" id="qPlus" aria-label="Increase">+</button>
            </div>
            <button type="submit" class="btn btn--primary btn--cart" id="addCart">
              <span>Add to cart</span><span class="dot">·</span><span id="ctaPrice">{{ unit_price }}</span>
            </button>
          </div>

          {% if additional_checkout_buttons %}
            <div class="btn btn--shoppay-wrap">{{ content_for_additional_checkout_buttons }}</div>
          {% else %}
            <button type="button" class="btn btn--shoppay">Buy with <b>Shop Pay</b></button>
          {% endif %}
        </form>

        <ul class="perks">
          <li><b>Free US shipping</b> on every order</li>
          <li><b>Ships in 24 hours</b> from California</li>
          <li><b>30-day money-back</b> — no questions</li>
          <li><b>2-year warranty</b> — replacement parts free</li>
        </ul>

        <div class="accord">
          <details open><summary>Details</summary><p>{{ section.settings.details }}</p></details>
          <details><summary>What's in the box</summary><ul><li>1 × {{ section.settings.sku_label }} pet hair remover</li><li>1 × Display stand</li><li>1 × Care card</li><li>0 × sticky sheets, ever</li></ul></details>
          <details><summary>Specs</summary><ul><li>Dimensions: 6.7" × 1.8"</li><li>Weight: 4.8 oz</li><li>Body: Recycled ABS</li><li>Replaceable head & chamber</li></ul></details>
          <details><summary>Shipping & returns</summary><p>Free US shipping, ships in 1 business day. International shipping calculated at checkout. 30-day money-back if it doesn't earn its spot in your home.</p></details>
        </div>
      </aside>

    </div>
  </section>

  <section class="strip">
    <div class="wrap strip__row">
      <div><span class="strip__num">2,300+</span><span class="strip__lbl">5-star reviews</span></div>
      <div><span class="strip__num">0</span><span class="strip__lbl">refills, forever</span></div>
      <div><span class="strip__num">∞</span><span class="strip__lbl">surfaces it works on</span></div>
      <div><span class="strip__num">30d</span><span class="strip__lbl">money-back trial</span></div>
    </div>
  </section>

  <section id="reviews" class="reviews">
    <div class="wrap reviews__grid">
      <div class="reviews__head">
        <span class="eyebrow">Reviews</span>
        <h2>4.9 out of 5.<br/><em>From people who own pets.</em></h2>
        <div class="reviews__stars" aria-hidden="true">★★★★★</div>
        <p class="reviews__sub">Based on 2,314 verified buyers</p>

        <ul class="rbreak" aria-label="Rating breakdown">
          <li><span>5</span><span class="bar"><span style="width:88%"></span></span><span>2,036</span></li>
          <li><span>4</span><span class="bar"><span style="width:8%"></span></span><span>185</span></li>
          <li><span>3</span><span class="bar"><span style="width:2%"></span></span><span>47</span></li>
          <li><span>2</span><span class="bar"><span style="width:1%"></span></span><span>23</span></li>
          <li><span>1</span><span class="bar"><span style="width:1%"></span></span><span>23</span></li>
        </ul>
      </div>

      <div class="reviews__list">
        <article class="rcard">
          <div class="rcard__top"><span class="rcard__stars">★★★★★</span><span class="rcard__date">2 days ago</span></div>
          <h3>Replaced 6 lint rollers in my house</h3>
          <p>I have two retrievers. I had a lint roller in every room and the cleaning lady used to dump them all in the trash weekly. One Dune, in the kitchen drawer, has replaced all of them. The car one is the only one I'll keep separate.</p>
          <span class="rcard__by">— Priya K. · Verified buyer · <em>Sage</em></span>
        </article>
        <article class="rcard">
          <div class="rcard__top"><span class="rcard__stars">★★★★★</span><span class="rcard__date">1 week ago</span></div>
          <h3>The couch finally looks clean</h3>
          <p>Bought it for the car, ended up using it on the couch the same day. Hair I'd given up on came right off. Looks good on the side table, doesn't look like a cleaning tool.</p>
          <span class="rcard__by">— Marcus T. · Verified buyer · <em>Cloud</em></span>
        </article>
        <article class="rcard">
          <div class="rcard__top"><span class="rcard__stars">★★★★★</span><span class="rcard__date">2 weeks ago</span></div>
          <h3>Husky season, defeated</h3>
          <p>If you have a double-coated dog you understand. I empty it twice a day during shedding season and it just keeps going. The chamber seal is the part I didn't know I needed — no hair clouds.</p>
          <span class="rcard__by">— Elise R. · Verified buyer · <em>Blush</em></span>
        </article>
        <article class="rcard">
          <div class="rcard__top"><span class="rcard__stars">★★★★☆</span><span class="rcard__date">3 weeks ago</span></div>
          <h3>Great. Wish it came with a wall mount</h3>
          <p>Works as advertised. Only feedback: I'd pay for a wall-mount accessory so it can live in the mudroom by the leashes.</p>
          <span class="rcard__by">— Jordan P. · Verified buyer · <em>Sky</em></span>
        </article>
        <article class="rcard">
          <div class="rcard__top"><span class="rcard__stars">★★★★★</span><span class="rcard__date">1 month ago</span></div>
          <h3>Goodbye Amazon lint roller subscription</h3>
          <p>I was on a recurring order for refills. Cancelled it. This pays for itself in 4 months and I'm done feeling guilty about the trash.</p>
          <span class="rcard__by">— Naomi B. · Verified buyer · <em>Sage</em></span>
        </article>
      </div>
    </div>
  </section>

  <section class="finalcta">
    <div class="wrap finalcta__inner">
      <h2>Try it for 30 days.<br/><em>Keep it for years.</em></h2>
      <p>If {{ product.title | default: 'Dune' }} doesn't earn its spot in your home, send it back. Full refund, no questions.</p>
      <a href="#productForm" class="btn btn--primary btn--lg">Add to cart · {{ unit_price }}</a>
    </div>
  </section>

</main>

<script>
(function(){
  var unitCents = {{ current_variant.price }};
  var qty = 1;
  var bundleLabel = 'Single · {{ unit_price }}';

  function fmt(cents){
    var dollars = Math.round(cents / 100);
    return '$' + dollars;
  }
  function recalc(){
    document.getElementById('ctaPrice').textContent = fmt(unitCents * qty);
    document.getElementById('qVal').value = qty;
    document.getElementById('bundlePick').textContent = bundleLabel;
  }

  document.querySelectorAll('.thumb').forEach(function(t){
    t.addEventListener('click', function(){
      document.querySelectorAll('.thumb').forEach(function(x){ x.classList.remove('is-active'); });
      t.classList.add('is-active');
      document.getElementById('mainImg').src = t.dataset.src;
    });
  });

  document.querySelectorAll('#colorRow .chip').forEach(function(c){
    c.addEventListener('click', function(){
      document.querySelectorAll('#colorRow .chip').forEach(function(x){ x.classList.remove('is-active'); });
      c.classList.add('is-active');
      document.getElementById('colorPick').textContent = c.dataset.name;
      document.getElementById('colorInput').value = c.dataset.name;
    });
  });

  document.querySelectorAll('#bundleRow .bundle').forEach(function(b){
    b.addEventListener('click', function(){
      document.querySelectorAll('#bundleRow .bundle').forEach(function(x){ x.classList.remove('is-active'); });
      b.classList.add('is-active');
      b.querySelector('input').checked = true;
      qty = parseInt(b.dataset.qty, 10) || 1;
      bundleLabel = b.dataset.label === 'Single · {{ unit_price }}' ? b.dataset.label : (b.dataset.label + ' · ' + fmt(unitCents * qty));
      recalc();
    });
  });

  document.getElementById('qPlus').addEventListener('click', function(){ qty++; recalc(); });
  document.getElementById('qMinus').addEventListener('click', function(){ if (qty > 1) { qty--; recalc(); } });
})();
</script>

{% schema %}
{
  "name": "Product",
  "settings": [
    { "type": "text", "id": "sku_label", "label": "SKU label", "default": "FA-01" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "The original" },
    { "type": "text", "id": "rating", "label": "Rating", "default": "4.9" },
    { "type": "text", "id": "review_count", "label": "Review count", "default": "2,314" },
    { "type": "text", "id": "lede", "label": "Pitch line", "default": "One reusable tool. Zero refills. Lifts pet hair, lint, and fuzz from every surface your dog calls a bed." },
    { "type": "text", "id": "compare_at_price", "label": "Compare-at price (fallback)", "default": "$34.99" },
    { "type": "textarea", "id": "details", "label": "Details copy", "default": "FA-01 is a refill-free pet hair remover engineered for everyday surfaces — woven couches, microfiber, denim, wool, cotton, leather, even cashmere. The self-cleaning head lifts hair on contact and seals it inside an empty-with-one-click chamber." }
  ],
  "presets": [
    { "name": "Product" }
  ]
}
{% endschema %}
